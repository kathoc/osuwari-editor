{
  "name": "osuwari-editor",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node --loader tsx server/index.ts",
    "ruby": "tsx src/ruby-engine/cli.ts",
    "test:ruby": "tsx --test src/ruby-engine/__tests__/*.test.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "kuromoji": "^0.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/kuromoji": "^0.1.3",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  }
}
