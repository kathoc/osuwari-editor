{
  "name": "osuwari-editor",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node --loader tsx server/index.ts",
    "ruby": "tsx src/ruby-engine/cli.ts",
    "test:ruby": "tsx --test src/ruby-engine/__tests__/*.test.ts",
    "electron:dev": "concurrently -k -n web,api,el -c blue,magenta,green \"npm:dev:web\" \"npm:dev:api\" \"wait-on tcp:5173 tcp:5174 && electron .\"",
    "electron:build:server": "node scripts/build-server.mjs",
    "electron:build": "npm run build && npm run electron:build:server",
    "rebuild:native": "electron-builder install-app-deps",
    "dist:mac": "npm run electron:build && electron-builder --mac"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "kuromoji": "^0.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/kuromoji": "^0.1.3",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.osuwari.editor",
    "productName": "Osuwari Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "build/**/*",
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/kuromoji/dict/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "icon/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    }
  }
}
